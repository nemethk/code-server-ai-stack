# .env.example
# Copy to .env and fill in values before running: cp .env.example .env
# NEVER commit .env to version control.

# ── code-server password ──────────────────────────────────────────────────────
# setup.sh will generate a random value if left blank.
CODE_SERVER_PASSWORD=

# Argon2 hashed password — takes precedence over CODE_SERVER_PASSWORD.
# setup.sh will generate this automatically if node/npx is on your host PATH.
# If setting manually: echo -n "yourpass" | npx argon2-cli -e
# WARNING: escape all $ signs in docker-compose values: $ → $$
HASHED_PASSWORD=

# ── TLS domain ────────────────────────────────────────────────────────────────
# Used in the self-signed cert's CN and SubjectAltName.
# Use 'localhost' for local access, or your LAN IP/hostname.
DOMAIN=localhost

# ── Anthropic / Claude Code CLI ───────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── OpenAI / Codex CLI ────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Google / Gemini CLI ───────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Optional: persist Claude login across container restarts ──────────────────
# Uncomment and set to your host ~/.claude directory path.
# CLAUDE_CONFIG_DIR=~/.claude
