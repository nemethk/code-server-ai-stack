# .env.example
# Copy to .env and fill in values before running: cp .env.example .env
# NEVER commit .env to version control.

# ── Tailscale ─────────────────────────────────────────────────────────────────
# Auth key from: https://login.tailscale.com/admin/settings/keys
# Create a reusable, non-ephemeral key so the node persists on the Tailnet.
TS_AUTHKEY=tskey-auth-...

# Hostname of the node on your Tailnet.
# Access URL will be: https://<TS_HOSTNAME>.<tailnet>.ts.net
TS_HOSTNAME=webai

# ── Anthropic / Claude Code CLI ───────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
# Leave blank to authenticate interactively with: claude auth login
ANTHROPIC_API_KEY=

# ── OpenAI / Codex CLI ────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Google / Gemini CLI ───────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
# Leave blank to authenticate interactively with: gemini auth login
GEMINI_API_KEY=

# ── Optional: persist Claude login across container restarts ──────────────────
# Uncomment and set to your host ~/.claude directory path.
# CLAUDE_CONFIG_DIR=~/.claude
